{
  "name": "atlantic-community-slides",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev storybook",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "storybook": "turbo run storybook",
    "build-storybook": "turbo run build-storybook",
    "export:decks": "pnpm --filter player build && node scripts/export-decks.mjs",
    "export:decks:images": "pnpm --filter player build && node scripts/export-decks.mjs --format images",
    "export:decks:pdf": "pnpm --filter player build && node scripts/export-decks.mjs --format pdf",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4"
    }
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  }
}
